{
    "Salm (função)": {
        "prefix": "salm",
        "body": [
            "salm ${1:nome} receiving ${2:param} of ${3|atom,fractional,word,dogma|} reveals ${4|void,atom,fractional,word,dogma|}",
            "\t${0:reveal ${5:0}}"
        ],
        "description": "Define um salm (função)"
    },

    "Salm sem parâmetros": {
        "prefix": "salm0",
        "body": [
            "salm ${1:nome} reveals ${2|void,atom,fractional,word,dogma|}",
            "\t${0:reveal ${3:0}}"
        ],
        "description": "Define um salm sem parâmetros"
    },

    "Salm genérico (com type parameter)": {
        "prefix": "salmg",
        "body": [
            "salm ${1:nome} of ${2:T} receiving ${3:param} of ${2:T} reveals ${2:T}",
            "\t${0:reveal ${3:param}}"
        ],
        "description": "Define um salm genérico com type parameter"
    },

    "Method Salm": {
        "prefix": "msalm",
        "body": [
            "salm ${1:nome} upon ${2:Scripture} reveals ${3|void,atom,fractional,word,dogma|}",
            "\t${0:reveal ${4:0}}"
        ],
        "description": "Define um method salm bindado a um scripture"
    },

    "Method Salm genérico": {
        "prefix": "msalmg",
        "body": [
            "salm ${1:nome} upon ${2:Scripture} of ${3:T} reveals ${4|void,atom,fractional,word,dogma|}",
            "\t${0:reveal ${5:0}}"
        ],
        "description": "Define um method salm genérico bindado a um scripture"
    },

    "Scripture (struct)": {
        "prefix": "scripture",
        "body": [
            "scripture ${1:Nome}",
            "\t${2:campo} of ${3|atom,fractional,word,dogma|}$0"
        ],
        "description": "Define um scripture (estrutura de dados)"
    },

    "Scripture genérico (com type parameter)": {
        "prefix": "scriptureg",
        "body": [
            "scripture ${1:Nome} of ${2:T}",
            "\t${3:value} of ${2:T}$0"
        ],
        "description": "Define um scripture genérico com type parameter"
    },

    "Sin (exceção)": {
        "prefix": "sin",
        "body": [
            "sin ${1:NomeSin}",
            "\t${2:message} of ${3|word,atom|}$0"
        ],
        "description": "Declara um sin (exceção lançável)"
    },

    "Sin sem campos": {
        "prefix": "sin0",
        "body": [
            "sin ${1:NomeSin}$0"
        ],
        "description": "Declara um sin sem campos"
    },

    "whether (if)": {
        "prefix": "whether",
        "body": [
            "whether ${1:condicao}",
            "\t${0:reveal 0}"
        ],
        "description": "Condicional whether"
    },

    "whether / otherwise (if/else)": {
        "prefix": "whetherwise",
        "body": [
            "whether ${1:condicao}",
            "\t${2:reveal 0}",
            "otherwise",
            "\t${0:reveal 1}"
        ],
        "description": "Condicional whether / otherwise"
    },

    "whether / otherwise so / otherwise (if/elif/else)": {
        "prefix": "whetherelse",
        "body": [
            "whether ${1:condicao}",
            "\t${2:reveal 0}",
            "otherwise so ${3:outra_condicao}",
            "\t${4:reveal 1}",
            "otherwise",
            "\t${0:reveal 2}"
        ],
        "description": "Condicional completo com otherwise so"
    },

    "litany for (loop)": {
        "prefix": "litany",
        "body": [
            "litany for ${1:condicao}",
            "\t${0:reveal 0}"
        ],
        "description": "Loop litany for (while)"
    },

    "forsake (break)": {
        "prefix": "forsake",
        "body": [
            "forsake"
        ],
        "description": "Sai imediatamente do litany (break)"
    },

    "ascend (continue)": {
        "prefix": "ascend",
        "body": [
            "ascend"
        ],
        "description": "Pula para a próxima iteração do litany (continue)"
    },

    "confess / answer for (try/catch)": {
        "prefix": "confess",
        "body": [
            "confess",
            "\t${1:hail proclaim praying \"tentativa\"}",
            "answer for ${2|DivisionByZero,InvalidArgumentCount,InvalidContext,InvalidDiscern,TypeError,UndefinedField,UndefinedMethod,UndefinedSalm,UndefinedScripture,UndefinedSin,UndefinedVariable,NomeSin|} as ${3:err}",
            "\t${0:hail proclaim praying \"erro capturado\"}"
        ],
        "description": "Bloco confess / answer for"
    },

    "confess / answer for / absolve (try/catch/finally)": {
        "prefix": "confessabs",
        "body": [
            "confess",
            "\t${1:hail proclaim praying \"tentativa\"}",
            "answer for ${2|DivisionByZero,InvalidArgumentCount,InvalidContext,InvalidDiscern,TypeError,UndefinedField,UndefinedMethod,UndefinedSalm,UndefinedScripture,UndefinedSin,UndefinedVariable,NomeSin|} as ${3:err}",
            "\t${4:hail proclaim praying \"erro\"}",
            "absolve",
            "\t${0:hail proclaim praying \"sempre\"}"
        ],
        "description": "Bloco confess / answer for / absolve (finally)"
    },

    "let there be (declaração sem valor)": {
        "prefix": "letbe",
        "body": [
            "let there be ${1:nome} of ${2|atom,fractional,word,dogma|}$0"
        ],
        "description": "Declara variável sem valor inicial"
    },

    "let there (declaração com valor)": {
        "prefix": "let",
        "body": [
            "let there ${1:nome} of ${2|atom,fractional,word,dogma|} be ${0:0}"
        ],
        "description": "Declara variável com valor"
    },

    "reveal (return)": {
        "prefix": "reveal",
        "body": [
            "reveal ${0:0}"
        ],
        "description": "Retorna um valor do salm"
    },

    "transgress (throw)": {
        "prefix": "transgress",
        "body": [
            "transgress ${1|DivisionByZero,InvalidArgumentCount,InvalidContext,InvalidDiscern,TypeError,UndefinedField,UndefinedMethod,UndefinedSalm,UndefinedScripture,UndefinedSin,UndefinedVariable,NomeSin|} praying ${0:\"mensagem\"}"
        ],
        "description": "Lança um sin"
    },

    "Builtin Sin: DivisionByZero": {
        "prefix": "sin.divzero",
        "body": [
            "answer for DivisionByZero as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura divisão por zero"
    },

    "Builtin Sin: InvalidArgumentCount": {
        "prefix": "sin.argc",
        "body": [
            "answer for InvalidArgumentCount as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura quantidade inválida de argumentos"
    },

    "Builtin Sin: InvalidContext": {
        "prefix": "sin.context",
        "body": [
            "answer for InvalidContext as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura uso inválido de contexto"
    },

    "Builtin Sin: InvalidDiscern": {
        "prefix": "sin.discern",
        "body": [
            "answer for InvalidDiscern as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura falhas de discern"
    },

    "Builtin Sin: TypeError": {
        "prefix": "sin.type",
        "body": [
            "answer for TypeError as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura erro de tipo"
    },

    "Builtin Sin: UndefinedField": {
        "prefix": "sin.field",
        "body": [
            "answer for UndefinedField as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura campo inexistente"
    },

    "Builtin Sin: UndefinedMethod": {
        "prefix": "sin.method",
        "body": [
            "answer for UndefinedMethod as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura method inexistente"
    },

    "Builtin Sin: UndefinedSalm": {
        "prefix": "sin.salm",
        "body": [
            "answer for UndefinedSalm as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura salm inexistente"
    },

    "Builtin Sin: UndefinedScripture": {
        "prefix": "sin.scripture",
        "body": [
            "answer for UndefinedScripture as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura scripture inexistente"
    },

    "Builtin Sin: UndefinedSin": {
        "prefix": "sin.sin",
        "body": [
            "answer for UndefinedSin as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura sin inexistente"
    },

    "Builtin Sin: UndefinedVariable": {
        "prefix": "sin.var",
        "body": [
            "answer for UndefinedVariable as ${1:err}",
            "\t${0:caught become message from err}"
        ],
        "description": "Captura variável indefinida"
    },

    "manifest (instanciar scripture ou covenant variant)": {
        "prefix": "manifest",
        "body": [
            "manifest ${1:ScriptureOrVariant} praying ${0:args}"
        ],
        "description": "Instancia um scripture ou uma covenant variant com dados"
    },

    "Covenant (enum unit variants)": {
        "prefix": "covenant",
        "body": [
            "covenant ${1:Nome}",
            "\t${2:VariantA}",
            "\t${0:VariantB}"
        ],
        "description": "Declara um covenant (enum) com variantes unit"
    },

    "Covenant com dados (enum data variants)": {
        "prefix": "covenantd",
        "body": [
            "covenant ${1:Nome}",
            "\t${2:VariantA}",
            "\t\t${3:campo} of ${4|atom,fractional,word,dogma|}",
            "\t${0:VariantB}"
        ],
        "description": "Declara um covenant com variante portando dados"
    },

    "discern com bearing (pattern match com dados)": {
        "prefix": "discernb",
        "body": [
            "discern ${1:variavel}",
            "\tas ${2:Variant} bearing ${3:binding}",
            "\t\t${0:hail proclaim praying binding}"
        ],
        "description": "Pattern match em covenant variant com extração de dados (bearing)"
    },

    "grace (Option) — granted": {
        "prefix": "granted",
        "body": [
            "manifest granted of grace of ${1|atom,fractional,word,dogma|} praying ${0:valor}"
        ],
        "description": "Instancia um grace::granted (Some) com valor"
    },

    "grace (Option) — absent": {
        "prefix": "absent",
        "body": [
            "absent of grace of ${0|atom,fractional,word,dogma|}"
        ],
        "description": "Instancia um grace::absent (None)"
    },

    "verdict (Result) — righteous": {
        "prefix": "righteous",
        "body": [
            "manifest righteous of verdict of ${1|atom,fractional,word,dogma|}, ${2|atom,fractional,word,dogma|} praying ${0:valor}"
        ],
        "description": "Instancia um verdict::righteous (Ok) com valor"
    },

    "verdict (Result) — condemned": {
        "prefix": "condemned",
        "body": [
            "manifest condemned of verdict of ${1|atom,fractional,word,dogma|}, ${2|atom,fractional,word,dogma|} praying ${0:\"razao\"}"
        ],
        "description": "Instancia um verdict::condemned (Err) com razão"
    },

    "discern grace (Option)": {
        "prefix": "discerngrace",
        "body": [
            "discern ${1:variavel}",
            "\tas granted bearing ${2:valor}",
            "\t\t${3:hail proclaim praying valor}",
            "\tas absent",
            "\t\t${0:hail proclaim praying \"nothing\"}"
        ],
        "description": "Pattern match em grace of T (granted | absent)"
    },

    "discern verdict (Result)": {
        "prefix": "discernverdict",
        "body": [
            "discern ${1:variavel}",
            "\tas righteous bearing ${2:valor}",
            "\t\t${3:hail proclaim praying valor}",
            "\tas condemned bearing ${4:razao}",
            "\t\t${0:hail proclaim praying razao}"
        ],
        "description": "Pattern match em verdict of T, E (righteous | condemned)"
    },

    "Covenant genérico (com type param)": {
        "prefix": "covenantg",
        "body": [
            "covenant ${1:Nome} of ${2:T}",
            "\t${3:Some}",
            "\t\t${4:value} of ${2:T}",
            "\t${0:None}"
        ],
        "description": "Declara um covenant genérico com type parameter"
    },

    "hail proclaim": {
        "prefix": "proclaim",
        "body": [
            "hail proclaim praying ${0:\"mensagem\"}"
        ],
        "description": "Imprime uma mensagem"
    },

    "become (atribuição)": {
        "prefix": "become",
        "body": [
            "${1:variavel} become ${0:0}"
        ],
        "description": "Atribui um valor a uma variável"
    },

    "Programa completo": {
        "prefix": "holy",
        "body": [
            "-- ${1:descrição do programa}",
            "",
            "${0}",
            "",
            "amen"
        ],
        "description": "Estrutura básica de um programa holy"
    },

    "hail com type arg (genérico)": {
        "prefix": "hailg",
        "body": [
            "hail ${1:nome} of ${2|atom,fractional,word,dogma|} praying ${0:args}"
        ],
        "description": "Chama um salm genérico com type argument explícito"
    },

    "hail aninhado com thus (arg não-final)": {
        "prefix": "hailtail",
        "body": [
            "hail ${1:outer} praying hail ${2:inner} praying ${3:args} thus and ${0:rest}"
        ],
        "description": "Chama salm aninhado onde o inner não é o último argumento; thus fecha arg list do inner"
    },

    "manifest variant de covenant (manifest Variant of Covenant)": {
        "prefix": "manifestv",
        "body": [
            "manifest ${1:Variant} of ${2:CovenantType} praying ${0:valor}"
        ],
        "description": "Instancia uma variant de covenant com dados"
    },

    "thus (fechar contexto)": {
        "prefix": "thus",
        "body": [
            "thus"
        ],
        "description": "Fecha o contexto aberto mais recente (type arg, arg list ou after)"
    },

    "after … thus (agrupamento)": {
        "prefix": "after",
        "body": [
            "after ${1:expr} thus"
        ],
        "description": "Agrupa uma sub-expressão (equivalente a parênteses)"
    },

    "hail word_of": {
        "prefix": "wordof",
        "body": [
            "hail word_of praying ${0:valor}"
        ],
        "description": "Converte um valor para word (string)"
    },

    "hail atom_of": {
        "prefix": "atomof",
        "body": [
            "hail atom_of praying ${0:\"texto\"}"
        ],
        "description": "Converte uma word para atom (inteiro)"
    },

    "let there com tipo genérico": {
        "prefix": "letg",
        "body": [
            "let there ${1:nome} of ${2:Type} of ${3|atom,fractional,word,dogma|} be ${0:manifest ${2:Type} praying}"
        ],
        "description": "Declara variável com tipo genérico (ex: grace of atom, Stack of T)"
    },

    "verdict — reveal righteous": {
        "prefix": "revealok",
        "body": [
            "reveal manifest righteous of verdict of ${1|atom,fractional,word,dogma|}, ${2|atom,fractional,word,dogma|} praying ${0:valor}"
        ],
        "description": "Retorna um verdict::righteous (Ok)"
    },

    "verdict — reveal condemned": {
        "prefix": "revealerr",
        "body": [
            "reveal manifest condemned of verdict of ${1|atom,fractional,word,dogma|}, ${2|atom,fractional,word,dogma|} praying ${0:\"razao\"}"
        ],
        "description": "Retorna um verdict::condemned (Err)"
    },

    "grace — reveal granted": {
        "prefix": "revealgranted",
        "body": [
            "reveal manifest granted of grace of ${1|atom,fractional,word,dogma|} praying ${0:valor}"
        ],
        "description": "Retorna um grace::granted (Some)"
    },

    "grace — reveal absent": {
        "prefix": "revealabsent",
        "body": [
            "reveal absent of grace of ${0|atom,fractional,word,dogma|}"
        ],
        "description": "Retorna um grace::absent (None)"
    }
}
